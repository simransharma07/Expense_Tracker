// HTTP Testing Script for Expense Tracker
// Test all syllabus topics with these requests

// ============================================
// SYLLABUS TOPIC: Response Methods & Routing
// ============================================

// 1. Test res.send() - Simple text response
GET http://localhost:3000/api/info

// 2. Test res.json() - JSON response
GET http://localhost:3000/api/status

// 3. Test res.sendFile() - Send file
GET http://localhost:3000/api/download-sample

// ============================================
// SYLLABUS TOPIC: Route Parameters
// ============================================

// 4. GET single expense by ID (/:id parameter)
GET http://localhost:3000/expenses/1709856000000
Headers: userid: test123

// 5. UPDATE expense by ID (/:id parameter)
PUT http://localhost:3000/expenses/1709856000000
Headers: 
  Content-Type: application/json
  userid: test123
Body:
{
  "title": "Updated Groceries",
  "amount": 3000,
  "category": "Food"
}

// 6. DELETE expense by ID (/:id parameter)
DELETE http://localhost:3000/expenses/1709942400000
Headers: userid: test123

// ============================================
// SYLLABUS TOPIC: Query Parameters
// ============================================

// 7. Sort expenses ascending
GET http://localhost:3000/expenses?sort=asc
Headers: userid: test123

// 8. Sort descending with limit
GET http://localhost:3000/expenses?sort=desc&limit=2
Headers: userid: test123

// ============================================
// SYLLABUS TOPIC: File Streaming
// ============================================

// 9. Stream log file (Read Stream)
GET http://localhost:3000/files/logs
Headers: userid: test123

// 10. Export expenses using streams (Write Stream)
GET http://localhost:3000/files/export-stream
Headers: userid: test123

// 11. Download expenses as CSV (res.download)
GET http://localhost:3000/files/download
Headers: userid: test123

// 12. Get file information
GET http://localhost:3000/files/info/expenses.json
Headers: userid: test123

// ============================================
// SYLLABUS TOPIC: CRUD Operations
// ============================================

// 13. GET all expenses
GET http://localhost:3000/expenses
Headers: userid: test123

// 14. POST create new expense
POST http://localhost:3000/expenses
Headers: 
  Content-Type: application/json
  userid: test123
Body:
{
  "title": "Internet Bill",
  "amount": 999,
  "category": "Utilities",
  "date": "2026-03-07T00:00:00.000Z"
}

// ============================================
// SYLLABUS TOPIC: Middleware & Error Handling
// ============================================

// 15. Test authentication middleware (missing userid)
GET http://localhost:3000/expenses
// Should return 403 Unauthorized

// 16. Test error handling middleware
GET http://localhost:3000/api/test-error

// 17. Test 404 handler
GET http://localhost:3000/invalid-route

// ============================================
// SYLLABUS TOPIC: Serving Static Files
// ============================================

// 18. Access static HTML files
GET http://localhost:3000/login.html
GET http://localhost:3000/register.html
GET http://localhost:3000/dashboard.html

// 19. Access static CSS
GET http://localhost:3000/style.css

// ============================================
// Authentication Routes
// ============================================

// 20. Register new user
POST http://localhost:3000/auth/register
Headers: Content-Type: application/json
Body:
{
  "email": "test@example.com",
  "password": "Test@1234"
}

// 21. Login user
POST http://localhost:3000/auth/login
Headers: Content-Type: application/json
Body:
{
  "email": "test@example.com",
  "password": "Test@1234"
}

// ============================================
// NOTES FOR TESTING
// ============================================

/*
1. APPLICATION-LEVEL MIDDLEWARE:
   - Every request logs to console and activity.log file
   - Request timing is calculated
   - CORS headers are added

2. ROUTER-LEVEL MIDDLEWARE:
   - Auth middleware checks 'userid' header
   - Applied to /expenses and /files routes

3. ERROR-HANDLING MIDDLEWARE:
   - Catches all errors with 4-parameter function
   - Sends proper error response

4. FILE MODULE FEATURES:
   - Synchronous: readFileSync, writeFileSync, appendFileSync
   - Asynchronous: fs.promises.readFile, fs.promises.writeFile
   - File stats: existsSync, statSync

5. FILE STREAMING:
   - Read Stream: createReadStream + pipe
   - Write Stream: createWriteStream with append flag
   - Streaming response: directly pipe to res

6. STATIC FILE SERVING:
   - express.static() serves /public folder
   - All HTML, CSS, JS files accessible

All syllabus topics covered! ✅
*/
